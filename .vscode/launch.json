{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CMake Debug (Terminal)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/UCRT64/HyVideo.exe",
            "args": [
                ":transcode:conf_out=b;c",
                "W:/test_a.mp4"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "CMake: 生成",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for LLDB",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}